  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/eslint-config-typescript": "13.0.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "9.33.0",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "1.6.1",
    "vue-tsc": "2.2.12"
  }
